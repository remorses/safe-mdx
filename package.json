{
    "name": "safe-mdx",
    "version": "1.5.0",
    "description": "Render MDX in React without eval, works in Cloudflare Workers and Vercel Edge",
    "type": "module",
    "main": "./dist/safe-mdx.js",
    "types": "./dist/safe-mdx.d.ts",
    "repository": {
        "type": "git",
        "url": "https://github.com/holocron-hq/safe-mdx"
    },
    "homepage": "https://github.com/holocron-hq/safe-mdx",
    "bugs": "https://github.com/holocron-hq/safe-mdx/issues",
    "exports": {
        "./package.json": "./package.json",
        ".": {
            "types": "./dist/safe-mdx.d.ts",
            "default": "./dist/safe-mdx.js"
        },
        "./parse": {
            "types": "./dist/parse.d.ts",
            "default": "./dist/parse.js"
        },
        "./client": {
            "types": "./dist/dynamic-esm-component.d.ts",
            "default": "./dist/dynamic-esm-component.js"
        },
        "./domparser": {
            "types": "./dist/html/domparser.d.ts",
            "browser": "./dist/html/domparser-browser.js",
            "default": "./dist/html/domparser.js"
        },
        "./src": {
            "types": "./src/safe-mdx.tsx",
            "default": "./src/safe-mdx.tsx"
        },
        "./src/*": {
            "types": "./src/*.tsx",
            "default": "./src/*.tsx"
        }
    },
    "scripts": {
        "build": "tsc",
        "compile": "tsc",
        "test": "vitest",
        "prepublishOnly": "rimraf dist \"*.tsbuildinfo\" && pnpm build",
        "demo": "vite",
        "start": "vite preview",
        "deploy-demo": "vite build && npx -y wrangler pages deploy",
        "demo:build": "vite build"
    },
    "files": [
        "dist",
        "src"
    ],
    "keywords": [
        "mdx",
        "react",
        "server-components",
        "rsc",
        "safe",
        "no-eval",
        "cloudflare-workers",
        "edge",
        "markdown"
    ],
    "author": "remorses <beats.by.morse@gmail.com>",
    "license": "MIT",
    "peerDependencies": {
        "react": "*"
    },
    "dependencies": {
        "@babel/parser": "^7.28.0",
        "@babel/types": "^7.28.2",
        "@standard-schema/spec": "^1.0.0",
        "collapse-white-space": "^2.1.0",
        "eval-estree-expression": "^3.0.0",
        "linkedom": "^0.18.12",
        "remark": "^15.0.1",
        "remark-frontmatter": "^5.0.0",
        "remark-gfm": "^4.0.0",
        "remark-mdx": "^3.0.0",
        "style-to-object": "^1.0.8",
        "unified": "^11.0.5",
        "unist-util-visit": "^5.0.0",
        "unist-util-visit-parents": "^6.0.1"
    },
    "devDependencies": {
        "@changesets/cli": "^2.28.1",
        "@tailwindcss/typography": "^0.5.16",
        "@tailwindcss/vite": "^4.1.11",
        "@types/estree-jsx": "^1.0.5",
        "@types/mdast": "^4.0.0",
        "@types/node": "^22.15.17",
        "@types/react": "^19.2.7",
        "@types/react-dom": "^19.2.3",
        "@types/unist": "^3.0.3",
        "@vitejs/plugin-react": "^4.7.0",
        "@vitest/coverage-v8": "^1.6.0",
        "dedent": "^1.5.1",
        "importmap-vite-plugin": "^0.0.0",
        "mdast-util-mdx-jsx": "^3.2.0",
        "react": "^19.2.1",
        "react-dom": "^19.2.1",
        "remark-parse": "^11.0.0",
        "remark-stringify": "^11.0.0",
        "rimraf": "^6.0.1",
        "tailwindcss": "^4.1.11",
        "typescript": "5.8.3",
        "vite": "^6.2.6",
        "vitest": "^3.1.3",
        "zod": "^4.1.12"
    }
}
