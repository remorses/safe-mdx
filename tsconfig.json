{
    "compilerOptions": {
        "allowImportingTsExtensions": true,
        "rewriteRelativeImportExtensions": true,
        "rootDir": "src",
        "outDir": "dist",
        "module": "nodenext",
        "moduleResolution": "nodenext",
        "target": "ESNext",
        "lib": ["ESNext", "DOM"],
        "jsx": "react-jsx",
        "declaration": true,
        "declarationMap": true,
        "sourceMap": true,
        "noEmit": false,
        "strict": true,
        "noImplicitAny": false,
        "noUncheckedIndexedAccess": true,
        "skipLibCheck": true,
        "useUnknownInCatchVariables": false
    },
    "include": ["src"]
}
